# WhatsApp Business API settings
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/<PHONE_NUMBER_ID>
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token

# Claude / Anthropic API
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_API_URL=https://api.anthropic.com/v1/complete

# Database connection
DATABASE_URL=postgresql://user:password@host:port/database

# WhatsApp webhook verification token
WHATSAPP_VERIFY_TOKEN=your_whatsapp_webhook_verify_token

# Primary WhatsApp destination number for reminders and briefings
TRAVELER_WHATSAPP_NUMBER=+1234567890

# Application port
PORT=4000
